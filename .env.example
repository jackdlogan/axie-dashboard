# Copy this file to .env and fill in your keys. .env is git-ignored.

# Sky Mavis GraphQL API — used for Axie trait/metadata enrichment
# (class, image, parts) keyed by token_id. Get one at https://developers.skymavis.com
SKYMAVIS_API_KEY=your_skymavis_key_here

# Dune Analytics API — the source of Ronin marketplace sale facts (nft.trades).
# Requires a paid Dune plan with API access. https://dune.com/settings/api
DUNE_API_KEY=your_dune_key_here

# Saved Dune query IDs (the numeric id in the query's URL: dune.com/queries/<ID>)
DUNE_QUERY_DAILY_METRICS=
DUNE_QUERY_TOP_SALES=
