# Copy this file to .env and fill in your keys. .env is git-ignored.

# Sky Mavis GraphQL API — used for Axie trait/metadata enrichment
# (class, image, parts) keyed by token_id. Get one at https://developers.skymavis.com
SKYMAVIS_API_KEY=your_skymavis_key_here

# Dune Analytics API — the source of Ronin marketplace sale facts (nft.trades).
# Requires a paid Dune plan with API access. https://dune.com/settings/api
DUNE_API_KEY=your_dune_key_here

# Saved Dune query IDs (the numeric id in the query's URL: dune.com/queries/<ID>)
DUNE_QUERY_DAILY_METRICS=
DUNE_QUERY_TOP_SALES=
# Optional: daily median settle price (USD) per collectible collection.
# Must return columns: day, collection, sales, median_usd. Leave blank to skip.
DUNE_QUERY_COLLECTIBLE_PRICES=

# --- Production hosting ---
# Dedicated VPS (bundled Caddy in Docker owns 80/443):
#   docker compose --profile caddy up -d --build
DOMAIN=dashboard.example.com
ACME_EMAIL=you@example.com

# Shared VPS (host Caddy/nginx already uses 80/443):
#   docker compose -f docker-compose.yml -f docker-compose.proxy.yml up -d --build
# Localhost port for reverse_proxy — must match deploy/caddy.host.example
DASHBOARD_HOST_PORT=8090
